{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "keyVaultName": {
            "defaultValue": "",
            "type": "String",
            "metadata": {
                "description": "Name of your EXISTING Key Vault (must already exist)."
            }
        },
        "TeamsWebhook": {
            "type": "securestring",
            "metadata": {
                "description": "Teams Webhook URL - will be stored as secret in your existing Key Vault."
            }
        },
        "location": {
            "type": "string",
            "defaultValue": "[resourceGroup().location]",
            "metadata": {
                "description": "Location for all resources."
            }
        }
    },
    "variables": {},
    "resources": [
        {
            "comments": "Stores TeamsWebhook secret in EXISTING Key Vault.",
            "type": "Microsoft.KeyVault/vaults/secrets",
            "apiVersion": "2023-07-01",
            "name": "[concat(parameters('keyVaultName'), '/TeamsWebhook')]",
            "location": "[parameters('location')]",
            "properties": {
                "value": "[parameters('TeamsWebhook')]",
                "attributes": {
                    "enabled": true
                }
            }
        },
        {
            "comments": "API Connection to existing Key Vault using Managed Identity.",
            "type": "Microsoft.Web/connections",
            "apiVersion": "2016-06-01",
            "name": "[parameters('keyVaultName')]",
            "location": "[parameters('location')]",
            "kind": "V1",
            "dependsOn": [
                "[resourceId('Microsoft.KeyVault/vaults/secrets', parameters('keyVaultName'), 'TeamsWebhook')]"
            ],
            "properties": {
                "displayName": "[parameters('keyVaultName')]",
                "parameterValueType": "Alternative",
                "alternativeParameterValues": {
                    "vaultName": "[parameters('keyVaultName')]"
                },
                "customParameterValues": {},
                "api": {
                    "id": "[subscriptionResourceId('Microsoft.Web/locations/managedApis', parameters('location'), 'keyvault')]"
                }
            }
        }
    ]
}
